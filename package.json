{
  "name": "tsoy-glasses",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "admin"
  ],
  "scripts": {
    "client": "npm run serve --workspace=client",
    "admin": "npm run dev --workspace=admin",
